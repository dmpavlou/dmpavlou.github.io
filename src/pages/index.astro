---
import "../styles/starwind.css"
import Layout from "@/layouts/Layout.astro";
import { Button } from "@/components/starwind/button";
import ProjectCard from "@/components/ProjectCard.astro";
import Project from "@/components/Project.astro";
---

<html lang="en">

<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dimitra Maria Pavlou</title>
</head>

<body class="text-gray-800 antialiased relative bg-transparent">
  <Layout>

    <!-- Main Content -->
    <main class="relative z-10 max-w-6xl mx-auto px-6 py-20">

      <!-- Title -->
      <h1 class="font-bold text-6xl p-3 heading text-center text-gray-900 drop-shadow-md">
        Dimitra Maria Pavlou
      </h1>

      <div class="h-12"></div>

      <!-- About Section -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">

        <!-- Text -->
        <div>
          <h2 class="font-extrabold text-3xl mb-4 text-gray-900">About</h2>

          <p class="leading-relaxed text-lg text-gray-800">
            Dimitra (she/her) is a music technologist from Greece. With curiosity for blending
            sound and technology, she experiments
            through composing music, designing soundscapes or developing interactive sound applications.
          </p>
          <br>
          <p class="leading-relaxed text-lg text-gray-800">
            She holds a Master’s degree in Sonic Arts from the University of Rome Tor Vergata, where she
            specialized in experimental audio production. Before that, she earned a Bachelor’s degree from the Department of Music Science & Art
            at the State University
            of Macedonia in Thessaloniki, as well as a violin diploma.
          </p>
          <br>
          <p class="leading-relaxed text-lg text-gray-800">
            As a performer and improviser, Dimitra has been featured in numerous concerts and festivals across Greece
            and Germany. Some of her appearances include the NORDLIED Festival at the Elbphilharmonie Hamburg, the
            blurred edges Festival with Chromatic Noise Collection at Künstlerhaus Faktor, performances at Resonanzraum
            St. Pauli with the impromptu.works ensemble and at the Museum für Kunst und Gewerbe Hamburg. As a member of
            the 6daEXIt Improvisation Ensemble, she has participated in performances at the Onassis Stegi in Athens and
            the Thessaloniki Concert Hall, among others.
            She has also gained experience in experimental audio production and sound design, 
            by working on projects such as "Fear makes Alice shrink" in collaboration with the Municipal Theatre of Ioannina, or by producing radio spots.
          </p>
          <br>
          <p class="leading-relaxed text-lg text-gray-800">
            In addition to her work in performance and audio production, Dimitra worked as a stage manager on the European 
            premiere of Cat Hope's contemporary opera "Speechless", as part of the Ligeti Festival in Hamburg. 
            She has also gained experience in live event production as an event technician and is currently 
            working as a media technician at the University of Music and Theatre in Munich.
          </p>
        </div>

        <!-- Portrait -->
       <!-- Centered Container -->
<div class="flex justify-center items-center py-10">
  <!-- Portrait Wrapper -->
  <div class="relative overflow-hidden rounded-[58%_42%_47%_53%/52%_68%_38%_58%] shadow-2xl border border-white/10 aspect-[3/4] w-56 sm:w-64 md:w-72 lg:w-80">
    
    <!-- Soft top highlight -->
    <div class="absolute inset-0 bg-gradient-to-b from-white/15 to-transparent mix-blend-overlay"></div>

    <!-- Portrait image -->
    <img
      src="/images/profilePhoto.jpg"
      alt="Portrait of Dimitra Maria Pavlou"
      loading="lazy"
      class="object-cover w-full h-full"
    />
  </div>
</div>






    </main>
  </Layout>
</body>

</html>